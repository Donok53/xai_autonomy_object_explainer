<launch>
  <arg name="planner_snapshot_topic" default="/xai/planner_snapshot"/>
  <arg name="event_log_topic" default="/xai/event_log"/>
  <arg name="output_topic" default="/xai/driving_explanations"/>
  <arg name="vlm_prompt_output_topic" default="/xai/driving_vlm_prompts"/>
  <arg name="vlm_explanation_output_topic" default="/xai/driving_vlm_explanations"/>
  <arg name="camera_image_topic" default="/camera/color/image_raw"/>
  <arg name="camera_info_topic" default="/camera/color/camera_info"/>
  <arg name="camera_overlay_output_topic" default="/xai/driving_camera_overlay"/>
  <arg name="scene_detector_point_cloud_topic" default="/planning/linefit_ground/non_ground_cloud"/>
  <arg name="scene_detector_cmd_vel_topic" default="/cmd_vel"/>
  <arg name="scene_detector_odom_topic" default="/lio_localizer/odometry/optimization"/>
  <arg name="publish_snapshot_updates" default="false"/>
  <arg name="enable_vlm_prompt_builder" default="false"/>
  <arg name="enable_vlm_inference" default="false"/>
  <arg name="enable_scene_detector" default="true"/>
  <arg name="enable_camera_overlay_viewer" default="true"/>
  <arg name="log_combined_explanation" default="true"/>
  <arg name="vlm_backend" default="ollama"/>
  <arg name="vlm_model" default="moondream"/>
  <arg name="vlm_endpoint" default="http://127.0.0.1:11434/api/chat"/>
  <arg name="vlm_image_detail" default="low"/>
  <arg name="vlm_log_explanation" default="true"/>
  <arg name="camera_display_window" default="true"/>
  <arg name="camera_render_mode" default="lidar_only"/>
  <arg name="camera_lidar_render_style" default="perspective_3d"/>
  <arg name="camera_show_detector_boxes" default="false"/>
  <arg name="camera_show_pointcloud_bbox" default="false"/>
  <arg name="camera_lidar_bev_max_forward_m" default="20.0"/>
  <arg name="camera_lidar_bev_rear_m" default="20.0"/>
  <arg name="camera_lidar_bev_half_width_m" default="20.0"/>
  <arg name="camera_lidar_bev_max_height_abs_m" default="2.0"/>
  <arg name="camera_lidar_bev_max_points" default="4000"/>
  <arg name="camera_lidar_canvas_width_px" default="1280"/>
  <arg name="camera_lidar_canvas_height_px" default="720"/>
  <arg name="camera_lidar_perspective_camera_back_factor" default="1.10"/>
  <arg name="camera_lidar_perspective_camera_height_factor" default="0.85"/>
  <arg name="camera_lidar_perspective_look_at_forward_factor" default="0.10"/>
  <arg name="camera_lidar_perspective_focal_scale" default="0.48"/>
  <arg name="camera_lidar_perspective_principal_y_ratio" default="0.70"/>
  <arg name="vlm_allowed_event_labels" default="path_blocked,path_update"/>
  <arg name="vlm_request_timeout_s" default="20.0"/>
  <arg name="vlm_min_request_interval_s" default="1.5"/>
  <arg name="vlm_max_image_arrival_age_s" default="1.5"/>
  <arg name="vlm_use_focus_crop" default="true"/>
  <arg name="vlm_focus_crop_margin_ratio" default="0.10"/>
  <arg name="vlm_max_image_side_px" default="288"/>
  <arg name="vlm_jpeg_quality" default="55"/>
  <arg name="vlm_image_match_tolerance_s" default="0.75"/>
  <arg name="scene_detector_backend" default="yolo_worker"/>
  <arg name="scene_detector_allowed_event_labels" default="path_blocked,path_update,state_update"/>
  <arg name="scene_detector_min_process_interval_s" default="0.25"/>
  <arg name="scene_detector_max_image_arrival_age_s" default="1.5"/>
  <arg name="scene_detector_max_point_cloud_dt_s" default="1.0"/>
  <arg name="scene_detector_use_focus_crop" default="true"/>
  <arg name="scene_detector_focus_crop_margin_ratio" default="0.12"/>
  <arg name="scene_detector_max_image_side_px" default="416"/>
  <arg name="scene_detector_point_cloud_buffer_size" default="12"/>
  <arg name="scene_detector_jpeg_quality" default="80"/>
  <arg name="scene_detector_yolo_request_timeout_s" default="3.0"/>
  <arg name="scene_detector_yolo_model" default="yolo11n.pt"/>
  <arg name="scene_detector_yolo_confidence_threshold" default="0.25"/>
  <arg name="scene_detector_yolo_iou_threshold" default="0.45"/>
  <arg name="scene_detector_yolo_max_det" default="8"/>
  <arg name="scene_detector_yolo_imgsz" default="320"/>
  <arg name="scene_detector_yolo_device" default="auto"/>
  <arg name="scene_detector_yolo_use_tracker" default="false"/>
  <arg name="scene_detector_yolo_tracker_config" default="bytetrack.yaml"/>
  <arg name="scene_detector_yolo_worker_python" default="/home/byeongjae/miniconda3/envs/vad/bin/python"/>
  <arg name="scene_detector_yolo_worker_script" default="$(find xai_driving_explainer)/scripts/yolo_ultralytics_worker.py"/>
  <arg name="scene_detector_track_hold_ttl_s" default="0.9"/>
  <arg name="scene_detector_track_iou_match_threshold" default="0.20"/>
  <arg name="scene_detector_track_center_match_px" default="120.0"/>
  <arg name="scene_detector_track_bbox_alpha" default="0.35"/>
  <arg name="scene_detector_track_label_decay" default="0.88"/>
  <arg name="scene_detector_track_min_hits" default="2"/>
  <arg name="scene_detector_use_motion_awareness" default="true"/>
  <arg name="scene_detector_motion_linear_speed_ref_mps" default="0.45"/>
  <arg name="scene_detector_motion_angular_speed_ref_radps" default="0.70"/>
  <arg name="scene_detector_motion_extra_hold_ttl_s" default="0.70"/>
  <arg name="scene_detector_motion_extra_center_match_px" default="100.0"/>
  <arg name="scene_detector_motion_label_decay_bonus" default="0.06"/>
  <arg name="scene_detector_motion_selected_track_bonus" default="0.35"/>
  <arg name="scene_detector_motion_selected_track_distance_px" default="140.0"/>
  <arg name="scene_detector_semantic_memory_enabled" default="true"/>
  <arg name="scene_detector_semantic_memory_match_radius_m" default="0.75"/>
  <arg name="scene_detector_semantic_memory_ttl_s" default="45.0"/>
  <arg name="scene_detector_semantic_memory_person_ttl_s" default="3.0"/>
  <arg name="scene_detector_semantic_memory_label_decay" default="0.985"/>
  <arg name="scene_detector_semantic_memory_min_hits" default="3"/>
  <arg name="scene_detector_semantic_memory_override_margin" default="0.08"/>
  <arg name="scene_detector_semantic_memory_position_alpha" default="0.25"/>
  <arg name="scene_detector_point_cloud_projection_enabled" default="true"/>
  <arg name="scene_detector_point_cloud_anchor_radius_m" default="0.45"/>
  <arg name="scene_detector_point_cloud_projection_max_range_m" default="6.0"/>
  <arg name="scene_detector_point_cloud_projection_max_points" default="350"/>
  <arg name="scene_detector_point_cloud_bev_forward_range_m" default="4.0"/>
  <arg name="scene_detector_point_cloud_bev_rear_range_m" default="0.6"/>
  <arg name="scene_detector_point_cloud_bev_half_width_m" default="2.5"/>
  <arg name="scene_detector_point_cloud_bev_max_height_abs_m" default="2.0"/>
  <arg name="scene_detector_point_cloud_bev_max_points" default="1400"/>
  <arg name="scene_detector_point_cloud_overlay_point_radius_px" default="2"/>
  <arg name="scene_detector_point_cloud_association_iou_threshold" default="0.03"/>
  <arg name="scene_detector_point_cloud_association_center_match_px" default="80.0"/>
  <arg name="scene_detector_point_cloud_use_tf" default="true"/>
  <arg name="scene_detector_point_cloud_fallback_transform_enabled" default="true"/>
  <arg name="scene_detector_point_cloud_fallback_source_frame" default="base_link"/>
  <arg name="scene_detector_point_cloud_fallback_target_frame" default="camera_color_optical_frame"/>
  <arg name="scene_detector_point_cloud_fallback_translation_xyz" default="[0.0, -0.05913, 0.0]"/>
  <arg name="scene_detector_point_cloud_fallback_rotation_xyzw" default="[-0.5, 0.5, -0.5, 0.5]"/>
  <arg name="camera_overlay_vlm_buffer_size" default="40"/>

  <node pkg="xai_driving_explainer"
        type="xai_driving_explainer_node.py"
        name="xai_driving_explainer"
        output="screen">
    <param name="planner_snapshot_topic" value="$(arg planner_snapshot_topic)"/>
    <param name="event_log_topic" value="$(arg event_log_topic)"/>
    <param name="output_topic" value="$(arg output_topic)"/>
    <param name="publish_snapshot_updates" value="$(arg publish_snapshot_updates)"/>
    <param name="log_combined_explanation" value="$(arg log_combined_explanation)"/>
  </node>

  <node if="$(arg enable_vlm_prompt_builder)"
        pkg="xai_driving_explainer"
        type="driving_vlm_prompt_builder.py"
        name="driving_vlm_prompt_builder"
        output="screen">
    <param name="input_topic" value="$(arg output_topic)"/>
    <param name="output_topic" value="$(arg vlm_prompt_output_topic)"/>
    <param name="allowed_event_labels" value="$(arg vlm_allowed_event_labels)"/>
  </node>

  <node if="$(arg enable_vlm_inference)"
        pkg="xai_driving_explainer"
        type="driving_vlm_inference_node.py"
        name="driving_vlm_inference"
        output="screen">
    <param name="prompt_topic" value="$(arg vlm_prompt_output_topic)"/>
    <param name="image_topic" value="$(arg camera_image_topic)"/>
    <param name="output_topic" value="$(arg vlm_explanation_output_topic)"/>
    <param name="backend" value="$(arg vlm_backend)"/>
    <param name="model" value="$(arg vlm_model)"/>
    <param name="endpoint" value="$(arg vlm_endpoint)"/>
    <param name="image_detail" value="$(arg vlm_image_detail)"/>
    <param name="log_vlm_explanation" value="$(arg vlm_log_explanation)"/>
    <param name="allowed_event_labels" value="$(arg vlm_allowed_event_labels)"/>
    <param name="request_timeout_s" value="$(arg vlm_request_timeout_s)"/>
    <param name="min_request_interval_s" value="$(arg vlm_min_request_interval_s)"/>
    <param name="max_image_arrival_age_s" value="$(arg vlm_max_image_arrival_age_s)"/>
    <param name="use_focus_crop" value="$(arg vlm_use_focus_crop)"/>
    <param name="focus_crop_margin_ratio" value="$(arg vlm_focus_crop_margin_ratio)"/>
    <param name="max_image_side_px" value="$(arg vlm_max_image_side_px)"/>
    <param name="jpeg_quality" value="$(arg vlm_jpeg_quality)"/>
  </node>

  <node if="$(arg enable_scene_detector)"
        pkg="xai_driving_explainer"
        type="driving_scene_detector_node.py"
        name="driving_scene_detector"
        output="screen">
    <param name="explanation_topic" value="$(arg output_topic)"/>
    <param name="image_topic" value="$(arg camera_image_topic)"/>
    <param name="camera_info_topic" value="$(arg camera_info_topic)"/>
    <param name="point_cloud_topic" value="$(arg scene_detector_point_cloud_topic)"/>
    <param name="output_topic" value="$(arg vlm_explanation_output_topic)"/>
    <param name="cmd_vel_topic" value="$(arg scene_detector_cmd_vel_topic)"/>
    <param name="odom_topic" value="$(arg scene_detector_odom_topic)"/>
    <param name="backend" value="$(arg scene_detector_backend)"/>
    <param name="allowed_event_labels" value="$(arg scene_detector_allowed_event_labels)"/>
    <param name="min_process_interval_s" value="$(arg scene_detector_min_process_interval_s)"/>
    <param name="max_image_arrival_age_s" value="$(arg scene_detector_max_image_arrival_age_s)"/>
    <param name="max_point_cloud_dt_s" value="$(arg scene_detector_max_point_cloud_dt_s)"/>
    <param name="point_cloud_buffer_size" value="$(arg scene_detector_point_cloud_buffer_size)"/>
    <param name="use_focus_crop" value="$(arg scene_detector_use_focus_crop)"/>
    <param name="focus_crop_margin_ratio" value="$(arg scene_detector_focus_crop_margin_ratio)"/>
    <param name="max_image_side_px" value="$(arg scene_detector_max_image_side_px)"/>
    <param name="jpeg_quality" value="$(arg scene_detector_jpeg_quality)"/>
    <param name="yolo_request_timeout_s" value="$(arg scene_detector_yolo_request_timeout_s)"/>
    <param name="yolo_model" value="$(arg scene_detector_yolo_model)"/>
    <param name="yolo_confidence_threshold" value="$(arg scene_detector_yolo_confidence_threshold)"/>
    <param name="yolo_iou_threshold" value="$(arg scene_detector_yolo_iou_threshold)"/>
    <param name="yolo_max_det" value="$(arg scene_detector_yolo_max_det)"/>
    <param name="yolo_imgsz" value="$(arg scene_detector_yolo_imgsz)"/>
    <param name="yolo_device" value="$(arg scene_detector_yolo_device)"/>
    <param name="yolo_use_tracker" value="$(arg scene_detector_yolo_use_tracker)"/>
    <param name="yolo_tracker_config" value="$(arg scene_detector_yolo_tracker_config)"/>
    <param name="yolo_worker_python" value="$(arg scene_detector_yolo_worker_python)"/>
    <param name="yolo_worker_script" value="$(arg scene_detector_yolo_worker_script)"/>
    <param name="track_hold_ttl_s" value="$(arg scene_detector_track_hold_ttl_s)"/>
    <param name="track_iou_match_threshold" value="$(arg scene_detector_track_iou_match_threshold)"/>
    <param name="track_center_match_px" value="$(arg scene_detector_track_center_match_px)"/>
    <param name="track_bbox_alpha" value="$(arg scene_detector_track_bbox_alpha)"/>
    <param name="track_label_decay" value="$(arg scene_detector_track_label_decay)"/>
    <param name="track_min_hits" value="$(arg scene_detector_track_min_hits)"/>
    <param name="use_motion_awareness" value="$(arg scene_detector_use_motion_awareness)"/>
    <param name="motion_linear_speed_ref_mps" value="$(arg scene_detector_motion_linear_speed_ref_mps)"/>
    <param name="motion_angular_speed_ref_radps" value="$(arg scene_detector_motion_angular_speed_ref_radps)"/>
    <param name="motion_extra_hold_ttl_s" value="$(arg scene_detector_motion_extra_hold_ttl_s)"/>
    <param name="motion_extra_center_match_px" value="$(arg scene_detector_motion_extra_center_match_px)"/>
    <param name="motion_label_decay_bonus" value="$(arg scene_detector_motion_label_decay_bonus)"/>
    <param name="motion_selected_track_bonus" value="$(arg scene_detector_motion_selected_track_bonus)"/>
    <param name="motion_selected_track_distance_px" value="$(arg scene_detector_motion_selected_track_distance_px)"/>
    <param name="semantic_memory_enabled" value="$(arg scene_detector_semantic_memory_enabled)"/>
    <param name="semantic_memory_match_radius_m" value="$(arg scene_detector_semantic_memory_match_radius_m)"/>
    <param name="semantic_memory_ttl_s" value="$(arg scene_detector_semantic_memory_ttl_s)"/>
    <param name="semantic_memory_person_ttl_s" value="$(arg scene_detector_semantic_memory_person_ttl_s)"/>
    <param name="semantic_memory_label_decay" value="$(arg scene_detector_semantic_memory_label_decay)"/>
    <param name="semantic_memory_min_hits" value="$(arg scene_detector_semantic_memory_min_hits)"/>
    <param name="semantic_memory_override_margin" value="$(arg scene_detector_semantic_memory_override_margin)"/>
    <param name="semantic_memory_position_alpha" value="$(arg scene_detector_semantic_memory_position_alpha)"/>
    <param name="point_cloud_projection_enabled" value="$(arg scene_detector_point_cloud_projection_enabled)"/>
    <param name="point_cloud_anchor_radius_m" value="$(arg scene_detector_point_cloud_anchor_radius_m)"/>
    <param name="point_cloud_projection_max_range_m" value="$(arg scene_detector_point_cloud_projection_max_range_m)"/>
    <param name="point_cloud_projection_max_points" value="$(arg scene_detector_point_cloud_projection_max_points)"/>
    <param name="point_cloud_bev_forward_range_m" value="$(arg scene_detector_point_cloud_bev_forward_range_m)"/>
    <param name="point_cloud_bev_rear_range_m" value="$(arg scene_detector_point_cloud_bev_rear_range_m)"/>
    <param name="point_cloud_bev_half_width_m" value="$(arg scene_detector_point_cloud_bev_half_width_m)"/>
    <param name="point_cloud_bev_max_height_abs_m" value="$(arg scene_detector_point_cloud_bev_max_height_abs_m)"/>
    <param name="point_cloud_bev_max_points" value="$(arg scene_detector_point_cloud_bev_max_points)"/>
    <param name="point_cloud_overlay_point_radius_px" value="$(arg scene_detector_point_cloud_overlay_point_radius_px)"/>
    <param name="point_cloud_association_iou_threshold" value="$(arg scene_detector_point_cloud_association_iou_threshold)"/>
    <param name="point_cloud_association_center_match_px" value="$(arg scene_detector_point_cloud_association_center_match_px)"/>
    <param name="point_cloud_use_tf" value="$(arg scene_detector_point_cloud_use_tf)"/>
    <param name="point_cloud_fallback_transform_enabled" value="$(arg scene_detector_point_cloud_fallback_transform_enabled)"/>
    <param name="point_cloud_fallback_source_frame" value="$(arg scene_detector_point_cloud_fallback_source_frame)"/>
    <param name="point_cloud_fallback_target_frame" value="$(arg scene_detector_point_cloud_fallback_target_frame)"/>
    <rosparam param="point_cloud_fallback_translation_xyz" subst_value="True">$(arg scene_detector_point_cloud_fallback_translation_xyz)</rosparam>
    <rosparam param="point_cloud_fallback_rotation_xyzw" subst_value="True">$(arg scene_detector_point_cloud_fallback_rotation_xyzw)</rosparam>
  </node>

  <node if="$(arg enable_camera_overlay_viewer)"
        pkg="xai_driving_explainer"
        type="driving_camera_overlay_viewer.py"
        name="driving_camera_overlay_viewer"
        output="screen">
    <param name="image_topic" value="$(arg camera_image_topic)"/>
    <param name="point_cloud_topic" value="$(arg scene_detector_point_cloud_topic)"/>
    <param name="explanation_topic" value="$(arg output_topic)"/>
    <param name="vlm_topic" value="$(arg vlm_explanation_output_topic)"/>
    <param name="output_topic" value="$(arg camera_overlay_output_topic)"/>
    <param name="display_window" value="$(arg camera_display_window)"/>
    <param name="render_mode" value="$(arg camera_render_mode)"/>
    <param name="lidar_render_style" value="$(arg camera_lidar_render_style)"/>
    <param name="show_detector_boxes" value="$(arg camera_show_detector_boxes)"/>
    <param name="show_pointcloud_bbox" value="$(arg camera_show_pointcloud_bbox)"/>
    <param name="vlm_image_match_tolerance_s" value="$(arg vlm_image_match_tolerance_s)"/>
    <param name="vlm_buffer_size" value="$(arg camera_overlay_vlm_buffer_size)"/>
    <param name="lidar_bev_max_forward_m" value="$(arg camera_lidar_bev_max_forward_m)"/>
    <param name="lidar_bev_rear_m" value="$(arg camera_lidar_bev_rear_m)"/>
    <param name="lidar_bev_half_width_m" value="$(arg camera_lidar_bev_half_width_m)"/>
    <param name="lidar_bev_max_height_abs_m" value="$(arg camera_lidar_bev_max_height_abs_m)"/>
    <param name="lidar_bev_max_points" value="$(arg camera_lidar_bev_max_points)"/>
    <param name="lidar_canvas_width_px" value="$(arg camera_lidar_canvas_width_px)"/>
    <param name="lidar_canvas_height_px" value="$(arg camera_lidar_canvas_height_px)"/>
    <param name="lidar_perspective_camera_back_factor" value="$(arg camera_lidar_perspective_camera_back_factor)"/>
    <param name="lidar_perspective_camera_height_factor" value="$(arg camera_lidar_perspective_camera_height_factor)"/>
    <param name="lidar_perspective_look_at_forward_factor" value="$(arg camera_lidar_perspective_look_at_forward_factor)"/>
    <param name="lidar_perspective_focal_scale" value="$(arg camera_lidar_perspective_focal_scale)"/>
    <param name="lidar_perspective_principal_y_ratio" value="$(arg camera_lidar_perspective_principal_y_ratio)"/>
  </node>
</launch>
